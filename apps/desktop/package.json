{
  "name": "@skye/desktop",
  "productName": "Skye",
  "description": "Premium desktop weather application",
  "author": "Bhav",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "package": "pnpm run build && node_modules\\.bin\\electron-builder.cmd --win portable",
    "package:store": "pnpm run build && node_modules\\.bin\\electron-builder.cmd --config electron-builder.store.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@skye/animations": "workspace:*",
    "@skye/core": "workspace:*",
    "@skye/shared-hooks": "workspace:*",
    "@skye/types": "workspace:*",
    "@skye/ui": "workspace:*",
    "@skye/weather-sdk": "workspace:*",
    "@tanstack/react-query": "^5.101.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.skye.weather",
    "productName": "Skye",
    "copyright": "© 2026 Skye Weather",
    "directories": {
      "output": "C:\\SkyeBuild",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "artifactName": "Skye-Setup.exe",
      "icon": "build/icon.png"
    },
    "appx": {
      "applicationId": "SkyeWeather",
      "backgroundColor": "#050810",
      "displayName": "Skye Weather",
      "identityName": "bhavkushwaha.SkyeWeather",
      "publisher": "CN=737A9450-867A-4C19-B65C-8FD65E9AFC7F",
      "publisherDisplayName": "bhavkushwaha",
      "languages": ["en-US"]
    },
    "mac": {
      "target": "dmg"
    }
  }
}
